    "@tanstack/react-query": "^5.90.2",
    "@trpc/client": "^11.6.0",
    "@trpc/react-query": "^11.6.0",
    "@trpc/server": "^11.6.0",
    "@types/cytoscape": "^3.21.9",
    "@types/react-cytoscapejs": "^1.2.6",
    "axios": "^1.12.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cookie": "^1.0.2",
    "cytoscape": "^3.33.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.2",
