{
  "name": "mtg-deck-mvp",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "build": "vite build && esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "seed:scryfall": "cross-env NODE_ENV=development tsx server/seed-scryfall.ts",
    "test:model": "cross-env NODE_ENV=development tsx server/scripts/regressionTest.ts",
    "teach": "cross-env NODE_ENV=development tsx server/scripts/fullBrainTraining.ts",
    "teach:arena": "cross-env NODE_ENV=development TRAINING_POOL_ARENA_ONLY=1 tsx server/scripts/fullBrainTraining.ts",
    "teach:20": "powershell -ExecutionPolicy Bypass -File scripts/teach-loop.ps1 -Count 20",
    "teach:arena:20": "powershell -ExecutionPolicy Bypass -File scripts/teach-loop.ps1 -Count 20 -Arena",
    "teach:loop": "powershell -ExecutionPolicy Bypass -File scripts/teach-loop.ps1",
    "check:learn": "cross-env NODE_ENV=development tsx server/scripts/checkCommanderWeights.ts",
    "calibrate:llm": "cross-env NODE_ENV=development tsx server/scripts/llmWeeklyCalibrator.ts",
    "signal:tournament": "cross-env NODE_ENV=development tsx server/scripts/applyTournamentSignal.ts",
    "db:health": "cross-env NODE_ENV=development tsx server/scripts/checkDbHealth.ts",
    "db:repair": "cross-env NODE_ENV=development tsx server/scripts/repairSynergies.ts",
    "db:repair-arena": "cross-env NODE_ENV=development tsx server/scripts/repairArenaFlag.ts",
    "db:heal": "cross-env NODE_ENV=development tsx server/scripts/autoHealDb.ts",
    "db:migrate": "cross-env NODE_ENV=development tsx server/scripts/applyMigration.ts",
    "rag:smoke": "cross-env NODE_ENV=development tsx server/scripts/smokeRag.ts",
    "rag:stats": "cross-env NODE_ENV=development tsx -e \"import('./server/services/ragCache').then(m=>m.getCacheStats()).then(s=>console.table([s]))\"",
    "embed:cards": "node scripts/run-python.mjs -m ml_engine.rag.pgvector_writer",
    "embed:cards:smoke": "node scripts/run-python.mjs -m ml_engine.rag.pgvector_writer --limit 100",
    "ml:server": "node scripts/run-python.mjs -m ml_engine.rag.server",
    "ml:test": "node scripts/run-python.mjs -m pytest ml_engine/forge_worker/tests -v",
    "train:ray": "node scripts/run-python.mjs -m ml_engine.ray_cluster.orchestrator --num-workers 2 --num-trials 2",
    "train:ray:arena": "cross-env TRAINING_POOL_ARENA_ONLY=1 node scripts/run-python.mjs -m ml_engine.ray_cluster.orchestrator --num-workers 2 --num-trials 2 --arena-only",
    "train:ray:smoke": "node scripts/run-python.mjs -m ml_engine.ray_cluster.orchestrator --num-workers 1 --num-trials 1 --budget-hours 0.02 --batch-size 200 --checkpoint-freq 1 --perturbation-interval 2",
    "train:ray:smoke:arena": "cross-env TRAINING_POOL_ARENA_ONLY=1 node scripts/run-python.mjs -m ml_engine.ray_cluster.orchestrator --num-workers 1 --num-trials 1 --budget-hours 0.02 --batch-size 200 --checkpoint-freq 1 --perturbation-interval 2 --arena-only",
    "forge:smoke": "node scripts/run-python.mjs -m ml_engine.ray_cluster.smoke_env",
    "forge:smoke:arena": "cross-env TRAINING_POOL_ARENA_ONLY=1 node scripts/run-python.mjs -m ml_engine.ray_cluster.smoke_env",
    "forge:smoke:multi": "node scripts/run-python.mjs -m ml_engine.ray_cluster.smoke_env_multi",
    "forge:smoke:multi:arena": "cross-env TRAINING_POOL_ARENA_ONLY=1 node scripts/run-python.mjs -m ml_engine.ray_cluster.smoke_env_multi",
    "stack:up": "powershell -ExecutionPolicy Bypass -File run-stack.ps1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.693.0",
    "@aws-sdk/s3-request-presigner": "^3.693.0",
    "@hookform/resolvers": "^5.2.2",
